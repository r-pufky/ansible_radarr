[Unit]
Description=Radarr Daemon.
After=network.target

[Service]
Type=simple
ExecStart={{ radarr__cfg._app_d ~ "/Radarr" }} -nobrowser -data={{ radarr___app._var_d }}
TimeoutStopSec=20
Restart=always
User={{ radarr__srv._user }}
Group={{ radarr__srv._group }}
UMask=0002
KillMode=process

[Install]
WantedBy=multi-user.target